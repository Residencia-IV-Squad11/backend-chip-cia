# API local para processar os atendimentos
LOCAL_API_URL=http://localhost:5000/api/atendimento/avaliar
LOCAL_API_TIMEOUT=60
LOCAL_API_RETRY=3

# Flask
FLASK_ENV=development
FLASK_DEBUG=True
SECRET_KEY=uma_chave_secreta_muito_forte_aqui

