# Renomeie este arquivo para .env e preencha os valores

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_NAME=chip_e_cia

# API Groq
GROQ_API_KEY=sua_chave_groq_aqui

# API externa para sync via cron
EXTERNAL_API_URL=https://api-externa.com/api/conversas/pendentes
